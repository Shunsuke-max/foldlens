# Server-only OpenAI credential. Never use a VITE_ prefix.
OPENAI_API_KEY=

# GPT-5.6 model used for grounded analysis.
OPENAI_MODEL=gpt-5.6-sol

# Set to true to force deterministic local analysis.
MOCK_ANALYSIS=false

# Live Responses API deadline in milliseconds (accepted range: 1000–30000).
ANALYSIS_TIMEOUT_MS=12000

# Public demo protection. Defaults: 20 requests per IP per hour.
ANALYSIS_RATE_LIMIT_MAX=20
ANALYSIS_RATE_LIMIT_WINDOW_MS=3600000

# Vercel serverless proxy only. Set this to the public Render service origin.
# Example: https://foldlens.onrender.com
RENDER_API_URL=

PORT=4178
